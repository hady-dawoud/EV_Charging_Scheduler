# API / deployment
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081,http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

# Database
POSTGRES_DB=ev_smart_charging
POSTGRES_USER=ev_user
POSTGRES_PASSWORD=change_me
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ev_user:change_me@postgres:5432/ev_smart_charging

# Strict feeder RL runtime / recommender
RECOMMENDATION_POLICY_NAME=rl_safety_preference
RL_SAFETY_FILTER_ENABLED=true
RL_SAFETY_FILTER_MODE=penalty
RL_SAFETY_FILTER_STRICT=true
RL_SAFETY_BLOCK_UNSAFE=false
RL_SAFETY_FILTER_PENALTY_WEIGHT=0.25
RL_SAFETY_MAPPING_MODE=stable_ordinal_demo_bridge
RL_FEEDER_CHECKPOINT_PATH=models/rl_feeder_final/maskable_ppo_feeder_station_selector.zip
FEEDER_RL_DATA_DIR=data/processed/evside_feeder_rl
GRID_ADVISORY_MODE=recorded
GRID_ADVISORY_REPLAY_DIR=data/processed/evside_feeder_rl
RL_POLICY_FAIL_CLOSED=true

# Local browser/mobile build
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
VITE_API_BASE_URL=http://localhost:8000

# Simulator
TOPOLOGY_SCENARIO_ID=
DYNAMIC_PRICING_ENABLED=true
ROUTING_PROVIDER_NAME=simple_distance
OSMNX_GRAPH_PATH=data/processed/routing/dundee_drive.graphml


# Auth
JWT_SECRET_KEY=change_me_to_a_long_random_secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Charger / simulator events
CHARGER_EVENT_SECRET=change_me_charger_event_secret
