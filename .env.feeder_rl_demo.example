# Opt-in PR 6.2 feeder RL safety demo.
#
# Without this file, the repository default remains deterministic
# RECOMMENDATION_POLICY_NAME=weighted_score with the safety filter disabled.
# This example contains no credentials and uses repository-relative paths.

RECOMMENDATION_POLICY_NAME=rl_safety_preference
RL_SAFETY_FILTER_ENABLED=true
RL_SAFETY_FILTER_MODE=penalty
RL_SAFETY_FILTER_STRICT=true
RL_SAFETY_BLOCK_UNSAFE=false
RL_SAFETY_FILTER_PENALTY_WEIGHT=0.25

# Preferred for physically matched app and feeder station identifiers:
# RL_SAFETY_MAPPING_MODE=exact_only
#
# Demo bridge for the current offline adapter. This mapping is deterministic
# but nonphysical and must not be used for primary grid-performance claims.
RL_SAFETY_MAPPING_MODE=stable_ordinal_demo_bridge

RL_FEEDER_CHECKPOINT_PATH=models/rl_feeder_final/maskable_ppo_feeder_station_selector.zip
FEEDER_RL_DATA_DIR=data/processed/evside_feeder_rl
GRID_ADVISORY_MODE=recorded
GRID_ADVISORY_REPLAY_DIR=data/processed/evside_feeder_rl

# Strict deployment fails closed instead of silently using a deterministic
# fallback when dependencies, artifacts, context, or inference are unavailable.
RL_POLICY_FAIL_CLOSED=true
