<resources>

    <!-- Android 12+ launch splash should match the React Native/web background. -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:editTextBackground">@drawable/rn_edit_text_material</item>
        <item name="android:windowBackground">@color/ev_background</item>
        <item name="android:windowSplashScreenBackground">@color/ev_background</item>
        <item name="android:windowSplashScreenIconBackgroundColor">@color/ev_background</item>
        <item name="android:colorAccent">#00FF00</item>
        <item name="android:navigationBarColor">@color/ev_background</item>
        <item name="android:statusBarColor">@color/ev_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

</resources>
